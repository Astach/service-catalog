# =============================================================================
# Redis (ElastiCache) - Example Variable Values
#
# Qovery built-in env var mappings:
#   TF_VAR_qovery_cluster_name   = {{QOVERY_KUBERNETES_CLUSTER_NAME}}
#   TF_VAR_region                = {{QOVERY_CLOUD_PROVIDER_REGION}}
#   TF_VAR_qovery_environment_id = {{QOVERY_ENVIRONMENT_ID}}
#   TF_VAR_qovery_project_id     = {{QOVERY_PROJECT_ID}}
# =============================================================================

qovery_cluster_name    = "qovery-z1234abcd"
region                 = "eu-west-3"
elasticache_identifier = "my-app-redis"
auth_token             = "change-me-to-a-strong-password-min-16-chars"

# elasticache_version          = "7.0"
# parameter_group_name         = "default.redis7"
# node_type                    = "cache.t4g.micro"
# port                         = 6379
# num_cache_clusters           = 1
# encrypt_disk                 = true
# transit_encryption_enabled   = true
# apply_changes_now            = false
# preferred_maintenance_window = "Tue:02:00-Tue:04:00"
# snapshot_retention_limit     = 14
# snapshot_window              = "00:00-01:00"
# skip_final_snapshot          = false
