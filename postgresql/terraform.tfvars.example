# =============================================================================
# PostgreSQL RDS - Example Variable Values
# Copy this file to terraform.tfvars and fill in your values.
#
# When running inside Qovery, most of these can be set as environment variables
# using the TF_VAR_ prefix + Qovery built-in variable interpolation:
#
#   TF_VAR_qovery_cluster_name   = {{QOVERY_KUBERNETES_CLUSTER_NAME}}
#   TF_VAR_region                = {{QOVERY_CLOUD_PROVIDER_REGION}}
#   TF_VAR_qovery_environment_id = {{QOVERY_ENVIRONMENT_ID}}
#   TF_VAR_qovery_project_id     = {{QOVERY_PROJECT_ID}}
#
# AWS credentials should be set as secrets:
#   AWS_ACCESS_KEY_ID     = <your-key>
#   AWS_SECRET_ACCESS_KEY = <your-secret>
# =============================================================================

# -- Required (Qovery context) -----------------------------------------------

qovery_cluster_name   = "qovery-z1234abcd"       # or use TF_VAR_ env var
region                = "eu-west-3"               # or use TF_VAR_ env var
qovery_environment_id = ""                        # or use TF_VAR_ env var
qovery_project_id     = ""                        # or use TF_VAR_ env var

# -- Required (instance) -----------------------------------------------------

postgresql_identifier = "my-app-postgresql"
password              = "change-me-to-a-strong-password"

# -- Instance Configuration ---------------------------------------------------

# instance_class      = "db.t3.micro"
# postgresql_version  = "16"
# port                = 5432
# storage_type        = "gp3"
# disk_size           = 20
# encrypt_disk        = true
# database_name       = "postgres"
# username            = "qovery"

# -- IOPS (only for io1/io2/gp3 when you need custom IOPS) -------------------

# enable_disk_iops = true
# disk_iops        = 3000

# -- Snapshot Restore (uncomment to restore from snapshot) --------------------

# snapshot_identifier = "rds:my-snapshot-id"

# -- Network Overrides (leave empty to auto-derive from EKS cluster) ----------

# vpc_id               = ""         # or use TF_VAR_vpc_id
# subnet_ids           = []
# security_group_ids   = []
# db_subnet_group_name = ""

# -- High Availability -------------------------------------------------------

# multi_az             = true
# publicly_accessible  = false

# -- Maintenance --------------------------------------------------------------

# apply_changes_now            = false
# allow_major_version_upgrade  = true
# auto_minor_version_upgrade   = true
# preferred_maintenance_window = "Tue:02:00-Tue:04:00"

# -- Monitoring ---------------------------------------------------------------

# performance_insights_enabled   = true
# performance_insights_retention = 7
# monitoring_interval            = 10    # set to 0 to disable enhanced monitoring

# -- Backup -------------------------------------------------------------------

# backup_retention_period  = 14
# preferred_backup_window  = "00:00-01:00"
# skip_final_snapshot      = false
# final_snapshot_name      = "final-snapshot"
# delete_automated_backups = false

# -- Tags ---------------------------------------------------------------------

# tags = {
#   Team  = "platform"
#   Owner = "alice"
# }
