    {
      "id": "console-detail",
      "type": "text",
      "x": 55,
      "y": 755,
      "width": 250,
      "height": 220,
      "text": "1. GET /catalog/blueprints\n   ?provider={cluster.cloud}\n   -> render catalog cards\n\n2. GET /catalog/blueprint/{name}\n   -> render variable form\n   - injected: shown read-only\n   - required: empty fields\n   - suggested: prefilled\n   - advanced: collapsed\n\n3. Alias preview:\n   compute prefix from name\n   show {PREFIX}_{OUTPUT}\n\n4. POST /catalog/terraform\n   {name, blueprint, vars}",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
