    {
      "id": "engine-detail",
      "type": "text",
      "x": 795,
      "y": 755,
      "width": 250,
      "height": 220,
      "text": "Standard EngineRequest\n  (no catalog flag)\n\nStandard TF service flow:\n  1. shallow fetch @SHA\n  2. terraform init\n  3. terraform plan\n  4. terraform apply\n  5. extract outputs\n     (QSM_* outputs work)\n\ngRPC -> q-core:\n  sendTerraformResources\n  (output key/value pairs)\n\nNo engine changes needed\nfor catalog services",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "seed": 42,
      "version": 2,
      "roundness": null,
      "boundElements": [],
      "updated": 1773216629377,
      "link": null,
      "locked": false,
      "groupIds": [
        "engine"
      ],
      "frameId": null,
      "isDeleted": false,
      "versionNonce": 573481931,
      "index": "af",
      "strokeStyle": "solid",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Standard EngineRequest\n  (no catalog flag)\n\nStandard TF service flow:\n  1. shallow fetch @SHA\n  2. terraform init\n  3. terraform plan\n  4. terraform apply\n  5. extract outputs\n     (QSM_* outputs work)\n\ngRPC -> q-core:\n  sendTerraformResources\n  (output key/value pairs)\n\nNo engine changes needed\nfor catalog services",
      "autoResize": true,
      "lineHeight": 1.0784313725490196
    },
