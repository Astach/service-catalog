    {
      "id": "core-detail",
      "type": "text",
      "x": 425,
      "y": 755,
      "width": 250,
      "height": 220,
      "text": "CatalogController\n  -> BlueprintRegistryService\n     fetch qsm.yml from GitHub\n     cache in ConcurrentHashMap\n\nCreateTerraformFromCatalogUseCase\n  -> resolve injected vars\n  -> validate user vars\n  -> TerraformDomain.create()\n  -> save (standard TF svc)\n\nOn deploy complete (gRPC):\n  AliasBridgeService\n  -> scan for QSM_* outputs\n  -> create {PREFIX}_{SUFFIX}\n     env vars (no flag check)",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "seed": 37,
      "version": 2,
      "roundness": null,
      "boundElements": [],
      "updated": 1773216629377,
      "link": null,
      "locked": false,
      "groupIds": [
        "core"
      ],
      "frameId": null,
      "isDeleted": false,
      "versionNonce": 954583109,
      "index": "aa",
      "strokeStyle": "solid",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CatalogController\n  -> BlueprintRegistryService\n     fetch qsm.yml from GitHub\n     cache in ConcurrentHashMap\n\nCreateTerraformFromCatalogUseCase\n  -> resolve injected vars\n  -> validate user vars\n  -> TerraformDomain.create()\n  -> save (standard TF svc)\n\nOn deploy complete (gRPC):\n  AliasBridgeService\n  -> scan for QSM_* outputs\n  -> create {PREFIX}_{SUFFIX}\n     env vars (no flag check)",
      "autoResize": true,
      "lineHeight": 1.1458333333333333
    },
